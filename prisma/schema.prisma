generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
  BRANCH_MANAGER
  EMPLOYEE
  CUSTOMER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  ONLINE
}

enum AppointmentSource {
  AI_CHAT
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  PHONE
  WALK_IN
  STAFF
}

enum ConversationSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBSITE_CHAT
  PHONE
  API
}

enum MessageRole {
  CUSTOMER
  AI
  STAFF
  SYSTEM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBSITE
  QR_CODE
  WALK_IN
  PHONE
  REFERRAL
  OTHER
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
  IN_APP
}

enum NotificationType {
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLATION
  APPOINTMENT_RESCHEDULE
  BIRTHDAY_WISH
  OFFER_PROMOTION
  FOLLOW_UP
  REVIEW_REQUEST
  REFERRAL_REQUEST
  CUSTOM
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Tenancy & Business ───────────────────────────────────────

model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  website   String?
  logo      String?
  about     String?
  timezone  String   @default("Asia/Kolkata")
  currency  String   @default("INR")
  isActive  Boolean  @default(true)
  subscriptionPlan String @default("TRIAL") // TRIAL, BASIC, PREMIUM, ENTERPRISE
  subscriptionExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  branches        Branch[]
  services        Service[]
  serviceCategories ServiceCategory[]
  customers       Customer[]
  employees       Employee[]
  conversations   Conversation[]
  users           User[]
  appointments    Appointment[]
  leads           Lead[]
  notifications   Notification[]
  settings        Setting[]

  @@map("businesses")
}

model Branch {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  address      String?
  city         String?
  state        String?
  pincode      String?
  phone        String?
  email        String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workingHours WorkingHour[]
  holidays     Holiday[]
  employees    Employee[]
  customers    Customer[]
  appointments Appointment[]
  services     Service[]

  @@map("branches")
}

model WorkingHour {
  id       String    @id @default(cuid())
  branchId String
  dayOfWeek DayOfWeek
  openTime String // "09:00"
  closeTime String // "19:00"
  isClosed Boolean   @default(false)

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, dayOfWeek])
  @@map("working_hours")
}

model Holiday {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  date      DateTime @db.Date
  isRecurring Boolean @default(false)

  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, date])
  @@map("holidays")
}

// ─── Users & Auth ─────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  businessId      String?
  email           String   @unique
  phone           String?
  passwordHash    String
  role            UserRole @default(CUSTOMER)
  isActive        Boolean  @default(true)
  isEmailVerified  Boolean  @default(false)
  refreshToken    String?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  business        Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee        Employee?

  @@map("users")
}

// ─── Employees / Staff ───────────────────────────────────────

model Employee {
  id              String   @id @default(cuid())
  businessId      String
  branchId        String?
  userId          String?  @unique
  name            String
  email           String?
  phone           String?
  photo           String?
  title           String?  // "Senior Stylist", "Colorist"
  bio             String?
  gender          Gender?
  isActive        Boolean  @default(true)
  color           String?  // calendar color
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch          Branch?         @relation(fields: [branchId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
  services        EmployeeService[]
  appointments    Appointment[]
  serviceAvailabilities ServiceAvailability[]

  @@map("employees")
}

model EmployeeService {
  employeeId String
  serviceId  String
  isPrimary  Boolean @default(false)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([employeeId, serviceId])
  @@map("employee_services")
}

model ServiceAvailability {
  id         String   @id @default(cuid())
  employeeId String
  dayOfWeek  DayOfWeek
  startTime  String
  endTime    String
  isAvailable Boolean @default(true)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("service_availabilities")
}

// ─── Services ────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  businessId  String
  branchId    String?
  name        String
  description String?
  duration    Int      // minutes
  price       Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal? @db.Decimal(10, 2)
  categoryId  String?
  category    ServiceCategory? @relation(fields: [categoryId], references: [id])
  color       String?  // UI color
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch        Branch?         @relation(fields: [branchId], references: [id])
  appointments  Appointment[]
  employees     EmployeeService[]

  @@map("services")
}

model ServiceCategory {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  color       String?  // UI color for category
  icon        String?  // Name of lucide icon
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services    Service[]

  @@unique([businessId, name])
  @@map("service_categories")
}

// ─── Appointments ────────────────────────────────────────────

model Appointment {
  id              String            @id @default(cuid())
  businessId      String
  branchId        String
  customerId      String
  employeeId      String?
  serviceId       String?
  startTime       DateTime
  endTime         DateTime
  duration        Int
  status          AppointmentStatus @default(PENDING)
  source          AppointmentSource @default(AI_CHAT)
  notes           String?
  cancelReason    String?
  rescheduleCount Int               @default(0)
  price           Decimal?          @db.Decimal(10, 2)
  isWalkIn        Boolean           @default(false)
  reminderSent    Boolean           @default(false)
  paymentStatus   PaymentStatus     @default(UNPAID)
  paymentMethod   PaymentMethod?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  version         Int               @default(1)

  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch          Branch      @relation(fields: [branchId], references: [id])
  customer        Customer    @relation(fields: [customerId], references: [id])
  employee        Employee?   @relation(fields: [employeeId], references: [id])
  service         Service?    @relation(fields: [serviceId], references: [id])
  conversation    Conversation?

  @@index([businessId, startTime])
  @@index([employeeId, startTime])
  @@index([customerId, startTime])
  @@index([branchId, startTime])
  @@map("appointments")
}

// ─── Customers / CRM ─────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  businessId      String
  branchId        String?
  userId          String?
  name            String
  email           String?
  phone           String?
  photo           String?
  gender          Gender?
  dateOfBirth     DateTime? @db.Date
  anniversary     DateTime? @db.Date
  notes           String?
  tags            String[]  // ["VIP", "Frequent", "New"]
  totalVisits     Int      @default(0)
  totalSpent      Decimal  @default(0) @db.Decimal(10, 2)
  loyaltyPoints   Int      @default(0)
  preferredEmployeeId String?
  lastVisitAt     DateTime?
  source          LeadSource?
  isVip           Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  branch          Branch?        @relation(fields: [branchId], references: [id])
  appointments    Appointment[]
  conversations   Conversation[]
  leads           Lead[]
  notifications   Notification[]

  @@index([businessId, phone])
  @@index([businessId, email])
  @@map("customers")
}

// ─── Conversations & AI Chat ─────────────────────────────────

model Conversation {
  id              String             @id @default(cuid())
  businessId      String
  customerId      String?
  appointmentId   String?            @unique
  source          ConversationSource
  externalId      String?            // WhatsApp ID, Instagram ID, etc.
  externalChannel String?            // "wa:phone", "ig:username"
  isActive        Boolean            @default(true)
  isAiManaging    Boolean            @default(true)
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  endedAt         DateTime?

  business        Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer?          @relation(fields: [customerId], references: [id])
  appointment     Appointment?       @relation(fields: [appointmentId], references: [id])
  messages        Message[]
  intentLogs      IntentLog[]

  @@index([businessId, customerId])
  @@index([externalId, source])
  @@map("conversations")
}

// ─── WhatsApp Session Storage ────────────────────────────────
model WhatsAppSession {
  id         String @id @default(cuid())
  businessId String
  keyId      String
  data       String @db.Text

  @@unique([businessId, keyId])
  @@map("whatsapp_sessions")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  contentType    String       @default("text") // text, image, document
  metadata       Json?
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model IntentLog {
  id             String   @id @default(cuid())
  conversationId String
  intent         String   // BOOK_APPOINTMENT, CANCEL, RESCHEDULE, QUESTION, GREETING, etc.
  confidence     Float
  rawInput       String
  extractedData  Json?
  resolved       Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("intent_logs")
}

// ─── Leads ───────────────────────────────────────────────────

model Lead {
  id         String     @id @default(cuid())
  businessId String
  customerId String?
  name       String
  phone      String?
  email      String?
  service    String?
  notes      String?
  source     LeadSource
  status     LeadStatus @default(NEW)
  assignedTo String?    // employee ID
  score      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id])

  @@index([businessId, status])
  @@index([businessId, source])
  @@map("leads")
}

// ─── Notifications ───────────────────────────────────────────

model Notification {
  id              String             @id @default(cuid())
  businessId      String
  customerId      String?
  channel         NotificationChannel
  type            NotificationType
  title           String
  body            String
  metadata        Json?
  scheduledAt     DateTime?
  sentAt          DateTime?
  readAt          DateTime?
  status          String             @default("PENDING") // PENDING, SENT, FAILED, READ
  error           String?
  createdAt       DateTime           @default(now())

  business        Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer?          @relation(fields: [customerId], references: [id])

  @@index([businessId, status])
  @@index([customerId])
  @@map("notifications")
}

// ─── Settings ────────────────────────────────────────────────

model Setting {
  id         String   @id @default(cuid())
  businessId String   @unique
  businessName String
  businessHours Json   // working hours config
  aiConfig     Json?  // AI personality, language, tone
  notificationConfig Json? // templates, channels, defaults
  generalConfig  Json? // currency, timezone, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("settings")
}

// ─── Audit Log ───────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity     String   // Appointment, Customer, Service, etc.
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
