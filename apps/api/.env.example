# AiSaloon OS - Backend Environment Variables
# Copy this file to Koyeb / Render environment configuration

# Server Configuration
PORT=4000
NODE_ENV=production

# JWT Authentication
# Generate a random 256-bit secure key: openssl rand -base64 32
JWT_SECRET="your_production_jwt_secret_here"
JWT_EXPIRES_IN="1d"

# Managed PostgreSQL (e.g. Neon.tech / Supabase)
# Replace with your actual Neon/Supabase Postgres URI
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"

# Managed Redis (e.g. Upstash)
# Replace with your actual Upstash Redis URI
REDIS_URL="redis://default:password@endpoint.upstash.io:32456"

# OpenAI API Key (For AI capabilities)
OPENAI_API_KEY="sk-proj-your_key"

# WhatsApp Business API (Evolution API / Meta)
WHATSAPP_API_URL="https://your-evolution-api-instance.com"
WHATSAPP_API_KEY="your-evolution-api-key"
